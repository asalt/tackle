<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FragPipe Methods Report</title>
  <style>
    :root {
      --bg: #f4f1ea;
      --card: #fffdf8;
      --ink: #262219;
      --muted: #6a6358;
      --line: #d9cfbc;
      --accent: #0b5a80;
      --missing: #b11f1f;
      --present: #196127;
    }
    body {
      margin: 0;
      padding: 0;
      background: radial-gradient(circle at 20% 0%, #fff8e9 0%, #f4f1ea 55%, #ece6db 100%);
      color: var(--ink);
      font: 15px/1.45 "IBM Plex Sans", "Trebuchet MS", sans-serif;
    }
    .main-container {
      max-width: 100% !important;
      margin: auto;
    }
    main {
      width: 100%;
      padding: 2rem 1rem 3rem 1rem;
      box-sizing: border-box;
    }
    h1, h2, h3 {
      font-family: "Source Serif 4", "Georgia", serif;
      margin: 0.6rem 0;
    }
    h1 { font-size: 2rem; }
    h2 {
      margin-top: 1.6rem;
      border-bottom: 1px solid var(--line);
      padding-bottom: 0.2rem;
    }
    section, .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 1rem;
      margin-top: 1rem;
      box-shadow: 0 2px 10px rgba(60, 44, 17, 0.08);
    }
    p.meta { color: var(--muted); margin: 0.3rem 0 0.8rem 0; }
    table { width: 100%; border-collapse: collapse; margin: 0.6rem 0 0.8rem 0; }
    th, td {
      border: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
      padding: 0.35rem 0.45rem;
    }
    th { background: #efe7d8; font-weight: 700; }
    code { font-family: "IBM Plex Mono", "Consolas", monospace; font-size: 0.92em; }
    .has-tip { text-decoration: underline dotted; cursor: help; }
    .missing { color: var(--missing); font-weight: 700; }
    .present { color: var(--present); font-weight: 700; }
    details { margin-top: 0.7rem; }
    summary { cursor: pointer; color: var(--accent); font-weight: 600; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 0.8rem; }
    ul { margin-top: 0.3rem; }
  </style>
</head>
<body>
  <main class="main-container">
    <h1>FragPipe Methods Report</h1>
    <p class="meta">Generated: {{ generated_at }}</p>
    <p class="meta">Inputs: <code>{{ input_dirs_text }}</code></p>
    <p class="meta">mzML tracking TSV: <code>{{ mzml_tsv_path }}</code></p>

    <section>
      <h2>Run Summary</h2>
      {{ run_summary_table_html | safe }}
    </section>

    <section>
      <h2>Run-to-Run Parameter Differences</h2>
      <p><strong>Workflow parameters that differ:</strong> {{ workflow_diff_count }}</p>
      {{ workflow_diff_table_html | safe }}
      <p><strong>fragger.params parameters that differ:</strong> {{ fragger_diff_count }}</p>
      {{ fragger_diff_table_html | safe }}
    </section>

    <section>
      <h2>mzML Manifest Tracking</h2>
      <p>Use this section to locate source spectra listed in each FragPipe manifest.</p>
      {{ manifest_table_html | safe }}
    </section>

    {{ run_sections_html | safe }}

    <section>
      <h2>Tool Versions</h2>
      {{ tool_versions_table_html | safe }}
    </section>

    {% if warnings %}
    <section>
      <h2>Warnings</h2>
      <ul>
        {% for item in warnings %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
  </main>
</body>
</html>
